{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'wasuuib@gmail.com' || auth.token.email == 'morningbosterapp@gmail.com')",
        ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'wasuuib@gmail.com' || auth.token.email == 'morningbosterapp@gmail.com')"
      }
    },
    "lessons": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'wasuuib@gmail.com' || auth.token.email == 'morningbosterapp@gmail.com')"
    },
    "onlineClasses": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'wasuuib@gmail.com' || auth.token.email == 'morningbosterapp@gmail.com')"
    },
    "students": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["email"]
    },
    "authorizedAdmins": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.email == 'morningbosterapp@gmail.com')"
    },
    "home": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'morningbosterapp@gmail.com')"
    },
    "paperResults": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'morningbosterapp@gmail.com')",
      ".indexOn": ["studentIndex", "paperNumber"]
    },
    "counters": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
